{
  "name": "ward-activity-board",
  "version": "1.0.0",
  "description": "Ward activity planning board with OAuth, CRUD APIs, and Swagger documentation.",
  "main": "server.js",
  "scripts": {
    "dev": "nodemon server.js",
    "start": "node server.js",
    "swagger": "node swagger.js",
    "seed": "node scripts/seed.js",
    "migrate:participants": "node scripts/migrate-participants.js",
    "check": "node scripts/check-syntax.js",
    "test": "npm run check && npm run swagger && node scripts/verify.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "connect-mongo": "^5.1.0",
    "dotenv": "^16.4.7",
    "ejs": "^3.1.10",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "express-session": "^1.18.1",
    "express-validator": "^7.2.1",
    "helmet": "^8.0.0",
    "method-override": "^3.0.0",
    "mongoose": "^8.10.0",
    "morgan": "^1.10.0",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "swagger-autogen": "^2.23.7",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "nodemon": "^3.1.9"
  }
